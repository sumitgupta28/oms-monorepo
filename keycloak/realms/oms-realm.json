{
  "realm": "oms",
  "enabled": true,
  "displayName": "Order Management System",
  "sslRequired": "none",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {"name":"CUSTOMER","description":"Regular customer"},
      {"name":"ADMIN","description":"System administrator"},
      {"name":"AGENT_MANAGER","description":"AI agent activity viewer"}
    ]
  },
  "defaultRoles": ["CUSTOMER"],
  "clients": [
    {
      "clientId": "react-ui",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"]
    },
    {
      "clientId": "gateway",
      "enabled": true,
      "publicClient": false,
      "secret": "gateway-secret-local",
      "bearerOnly": false,
      "serviceAccountsEnabled": true
    }
  ],
  "users": [
    {
      "username": "admin@oms.com",
      "email": "admin@oms.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "System",
      "lastName": "Admin",
      "credentials": [{"type":"password","value":"admin123","temporary":false}],
      "realmRoles": ["ADMIN","CUSTOMER","AGENT_MANAGER"]
    },
    {
      "username": "customer@oms.com",
      "email": "customer@oms.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "Customer",
      "credentials": [{"type":"password","value":"customer123","temporary":false}],
      "realmRoles": ["CUSTOMER"]
    }
  ],
  "eventsEnabled": true,
  "eventsExpiration": 2592000,
  "enabledEventTypes": [
    "LOGIN","LOGIN_ERROR","LOGOUT","REGISTER","REGISTER_ERROR",
    "UPDATE_PASSWORD","RESET_PASSWORD","TOKEN_REFRESH"
  ],
  "adminEventsEnabled": true
}
