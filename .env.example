# Copy this file to .env and fill in your values
# Never commit .env to Git

# ── AI Provider ────────────────────────────────────────────────────────────────
# Set to "anthropic" (default) or "ollama"
AI_PROVIDER=anthropic

# Anthropic API key — required when AI_PROVIDER=anthropic
# Get from https://console.anthropic.com (leave empty when using Ollama)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model name override (optional)
# Anthropic default: claude-sonnet-4-6
# Ollama default:    llama3.2
# AI_MODEL=claude-sonnet-4-6

# Max token limit (optional, default: 4096)
# AI_MAX_TOKENS=4096

# Ollama base URL — only used when AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434

# ── Keycloak ───────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Spring ─────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
